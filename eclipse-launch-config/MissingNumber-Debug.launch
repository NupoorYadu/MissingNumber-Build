        <mapEntry key="hostname" value="localhost"/>
        <mapEntry key="port" value="5005"/>
    </mapAttribute>
    <stringAttribute name="org.eclipse.jdt.launching.CONNECTION_TYPE" value="socket"/>
    <stringAttribute name="org.eclipse.jdt.launching.PROJECT_ATTR" value="missing-number"/>
    <stringAttribute name="org.eclipse.jdt.launching.VM_CONNECTOR_ID" value="org.eclipse.jdt.launching.socketAttachConnector"/>
</launchConfiguration>
