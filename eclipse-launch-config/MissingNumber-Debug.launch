<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<launchConfiguration type="org.eclipse.jdt.launching.remoteJavaApplication">
    <stringAttribute name="org.eclipse.debug.core.source_locator_id" value="org.eclipse.jdt.launching.sourceLocator.JavaSourceLocator"/>
    <stringAttribute name="org.eclipse.debug.core.source_locator_memento" value="&lt;?xml version=&quot;1.0&quot; encoding=&quot;UTF-8&quot; standalone=&quot;no&quot;?&gt;&#10;&lt;sourceLookupDirector&gt;&#10;&lt;sourceContainers duplicateId=&quot;org.eclipse.jdt.launching.source_path_provider&quot;/&gt;&#10;&lt;/sourceLookupDirector&gt;&#10;"/>
    <listAttribute name="org.eclipse.debug.core.MAPPED_RESOURCE_PATHS">
        <listEntry value="/missing-number"/>
    </listAttribute>
    <listAttribute name="org.eclipse.debug.core.MAPPED_RESOURCE_TYPES">
        <listEntry value="4"/>
    </listAttribute>
    <booleanAttribute name="org.eclipse.jdt.launching.ALLOW_TERMINATE" value="true"/>
